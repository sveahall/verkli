{
  "name": "verkli-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -w @verkli/web dev",
    "build": "npm run -w @verkli/web build",
    "start": "npm run -w @verkli/web start",
    "lint": "npm run -w @verkli/web lint",
    "check:no-placeholders": "npm run -w @verkli/web check:no-placeholders",
    "check:no-prisma": "(test -d node_modules/@prisma/client || test -d node_modules/prisma) && (echo 'Prisma found in node_modules' && exit 1); exit 0"
  },
  "dependencies": {
    "@runwayml/sdk": "^3.11.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "ogl": "^1.0.11",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "three": "^0.167.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
