{
  "name": "verkli-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run -w @verkli/web dev",
    "build": "npm run -w @verkli/web build",
    "build:ci": "rm -rf apps/web/.next && npm run -w @verkli/web build:ci",
    "clean": "rm -rf apps/web/.next",
    "test": "npm run -w @verkli/web test",
    "test:e2e": "npm run -w @verkli/web test:e2e",
    "start": "npm run -w @verkli/web start",
    "lint": "npm run -w @verkli/web lint",
    "desktop": "electron electron-main.js",
    "start-workers": "npm run -w @verkli/web start-workers",
    "import-worker": "npm run -w @verkli/web import-worker",
    "translate-worker": "npm run -w @verkli/web translate-worker",
    "audiobook-worker": "npm run -w @verkli/web audiobook-worker",
    "tts-preview-worker": "npm run -w @verkli/web tts-preview-worker",
    "tts-lab-worker": "npm run -w @verkli/web tts-preview-worker",
    "social-publish-worker": "npm run -w @verkli/web social-publish-worker",
    "notifications-worker": "npm run -w @verkli/web notifications-worker",
    "combined-worker": "npm run -w @verkli/web combined-worker",
    "recommendations-worker": "npm run -w @verkli/web recommendations-worker",
    "tts:bench": "python3 scripts/tts-bench.py",
    "check:no-placeholders": "npm run -w @verkli/web check:no-placeholders",
    "check:no-prisma": "(test -d node_modules/@prisma/client || test -d node_modules/prisma) && (echo 'Prisma found in node_modules' && exit 1); exit 0",
    "prepare": "husky",
    "update": "npm install && npm run generate -w @verkli/db"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.1",
    "dotenv": "^17.3.1",
    "next": "^16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^34.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
