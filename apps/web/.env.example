# ─── Public (NEXT_PUBLIC_* = exposed to client) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server only (never use in client components) ───
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Optional: Waitlist mode ───
# NEXT_PUBLIC_WAITLIST_ONLY=false

# ─── Book import pipeline (BullMQ + Redis) ───
# Required for import worker. Start Redis: docker compose up -d (see docker-compose.yml in repo root)
REDIS_URL=redis://localhost:6379
# Optional: local import files dir when not using Supabase Storage
# LOCAL_IMPORTS_DIR=.uploads/imports

# ─── Feature flags (default: true when unset) ───
# NEXT_PUBLIC_TRANSLATIONS_ENABLED=false   → UI shows "Coming soon" for Translations; import still works

# ─── FAS 5: Beta + Feedback ───
# BETA_LOCK=false
# ADMIN_API_KEY=your-admin-api-key
