# Supabase (client)
# URL and service_role must point to the SAME project you use in Table Editor
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server only – never expose to client)
# If SERVICE ROLE SET is false in API logs, RLS will block inserts
SUPABASE_SERVICE_ROLE_KEY=

# Resend (server only – waitlist confirmation email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Verkli <hello@verkli.ai>

# Runway ML (text-to-video)
RUNWAYML_API_SECRET=

# Optional CLI defaults
RUNWAY_PROMPT_TEXT=
RUNWAY_DURATION=
RUNWAY_RATIO=
RUNWAY_AUDIO=
