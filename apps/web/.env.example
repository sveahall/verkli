# Copy this file to apps/web/.env.local and fill in your values.
# Node workers always load apps/web/.env.local regardless of cwd.

# ─── Public (NEXT_PUBLIC_* = exposed to client) ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_PLACEHOLDER_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server only (never use in client components) ───
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PRICE_PLUS=price_plus_monthly_id
PRICE_PRO=price_pro_monthly_id
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/account/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/account/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/account/billing?checkout=cancel

# ─── Optional: Waitlist mode ───
# NEXT_PUBLIC_WAITLIST_ONLY=false

# ─── Book import pipeline (BullMQ + Redis) ───
# Required for import worker. Start Redis: docker compose up -d (see docker-compose.yml in repo root)
REDIS_URL=redis://localhost:6379
# Optional: local import files dir when not using Supabase Storage
# LOCAL_IMPORTS_DIR=.uploads/imports

# ─── Translation pipeline (after import) ───
# TRANSLATIONS_AUTO_ENQUEUE=true          → enqueue translation jobs after import (requires translate-worker)
# TRANSLATIONS_TARGET_LANGUAGES=sv,de,fr  → comma-separated target languages (only non-original enqueued)
# OPUSMT_PYTHON=/abs/path/to/venv/bin/python   → Python venv with ctranslate2 + sentencepiece
# OPUSMT_MODELS_DIR=/abs/path/to/apps/web/models → contains subdir sv_en with model.bin + spm files

# ─── Feature flags ───
# NEXT_PUBLIC_TRANSLATIONS_ENABLED=false   → UI shows "Coming soon" for Translations; import still works
# AUDIOBOOK_ENABLED=true                   → enable audiobook API endpoints (default OFF when unset)
# NEXT_PUBLIC_AUDIOBOOK_ENABLED=true       → show audiobook UI (default OFF when unset)
# OFFLINE_READING_ENABLED=true             → enable offline manifest/chapter API endpoints
# NEXT_PUBLIC_OFFLINE_READING_ENABLED=true → show offline save UI + service worker registration

# ─── Audiobook narration ───
# TTS_DAILY_BUDGET=500000
# TRANSLATION_DAILY_BUDGET=500000
# VIDEO_DAILY_BUDGET=100
# AUDIOBOOK_STORAGE_BUCKET=audiobooks
# QWEN_TTS_PYTHON=/abs/path/to/qwen3tts-env/bin/python3.12
# QWEN_TTS_SCRIPT=/abs/path/to/apps/web/scripts/qwen_tts_synthesize.py
# QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
# AI_NARRATOR_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
# QWEN_TTS_VOICE_ID=Ryan
# QWEN_TTS_TIMEOUT_MS=300000
# TTS_MAX_CHARS=350
# QWEN_TTS_BATCH_SIZE=1
# QWEN_TTS_MAX_NEW_TOKENS=2048
# QWEN_TTS_XVECTOR_ONLY=1
# QWEN_TTS_CLONE_NON_STREAMING_MODE=0
# QWEN_TTS_DEVICE=auto            # auto|cuda|cuda:0|mps|cpu
# TTS_DTYPE=auto                  # auto|bf16|fp16|fp32
# TTS_AUTOCAST=1                  # CUDA autocast (safe default on)
# TTS_FLASH_ATTN=1                # try flash_attention_2 on CUDA
# TTS_TORCH_COMPILE=0             # optional torch.compile reduce-overhead
# TTS_TORCH_COMPILE_MODE=reduce-overhead
# TTS_INT8=0                      # optional bitsandbytes-style int8 load
# TTS_CONCURRENCY=1               # audiobook worker job concurrency
# QWEN_TTS_VERBOSE=0
# RUN_QWEN_TTS_GOLDEN=0           # set 1 to run opt-in golden integration test
# Create buckets in Supabase Storage: `book_covers` can be public, `audiobooks` must be private.

# ─── FAS 5: Beta + Feedback ───
# BETA_LOCK=false
# ADMIN_API_KEY=your-admin-api-key
