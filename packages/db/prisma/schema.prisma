generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Users & Auth (synkad med Supabase Auth)
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @db.Uuid // Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  role      UserRole @default(READER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  books    Book[]    @relation("AuthorBooks")
  readings Reading[]
  reviews  Review[]
  shelves  Shelf[]

  @@map("users")
}

enum UserRole {
  READER
  AUTHOR
  ADMIN
}

// ─────────────────────────────────────────────────────────────
// Books & Content
// ─────────────────────────────────────────────────────────────

model Book {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  slug        String      @unique
  description String?     @db.Text
  coverImage  String?     @map("cover_image")
  status      BookStatus  @default(DRAFT)
  authorId    String      @map("author_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  publishedAt DateTime?   @map("published_at") @db.Timestamptz

  // Relations
  author      User         @relation("AuthorBooks", fields: [authorId], references: [id])
  chapters    Chapter[]
  readings    Reading[]
  reviews     Review[]
  shelfBooks  ShelfBook[]

  @@index([authorId])
  @@index([status])
  @@map("books")
}

enum BookStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  order     Int
  bookId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, order])
  @@index([bookId])
  @@map("chapters")
}

// ─────────────────────────────────────────────────────────────
// Reader Interactions
// ─────────────────────────────────────────────────────────────

model Reading {
  id              String   @id @default(cuid())
  userId          String
  bookId          String
  currentChapter  Int      @default(1)
  progressPercent Float    @default(0)
  startedAt       DateTime @default(now())
  lastReadAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("readings")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  rating    Int
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@map("reviews")
}

// ─────────────────────────────────────────────────────────────
// Library & Shelves
// ─────────────────────────────────────────────────────────────

model Shelf {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String
  subtitle    String?
  coverUrl    String?  @map("cover_url")
  coverType   String   @default("image") @map("cover_type") // 'image' | 'gradient'
  coverGradient String? @map("cover_gradient") // JSON string
  typography  Json?    @default("{}") // { fontFamily, fontWeight, titleSize, subtitleSize, textColor }
  sortIndex   Int      @default(0) @map("sort_index")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sections    ShelfSection[]
  shelfBooks  ShelfBook[]

  @@index([userId])
  @@index([userId, sortIndex])
  @@map("shelves")
}

model ShelfSection {
  id        String   @id @default(uuid()) @db.Uuid
  shelfId   String   @map("shelf_id") @db.Uuid
  name      String
  sortIndex Int      @default(0) @map("sort_index")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  shelf      Shelf       @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  shelfBooks ShelfBook[]

  @@index([shelfId])
  @@index([shelfId, sortIndex])
  @@map("shelf_sections")
}

model ShelfBook {
  id        String   @id @default(uuid()) @db.Uuid
  shelfId   String   @map("shelf_id") @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  sectionId String?  @map("section_id") @db.Uuid
  sortIndex Int      @default(0) @map("sort_index")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  shelf    Shelf         @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  book     Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section  ShelfSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  @@unique([shelfId, bookId])
  @@index([shelfId])
  @@index([bookId])
  @@index([sectionId])
  @@index([shelfId, sectionId, sortIndex])
  @@map("shelf_books")
}
