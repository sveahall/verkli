# ─────────────────────────────────────────────────────────────
# Verkli Environment Variables
# ─────────────────────────────────────────────────────────────
# 
# This file contains all required environment variables for the Verkli app.
# Copy this to .env.local and fill in your actual values.
# 
# IMPORTANT: 
# - Never commit .env.local to git (it contains secrets)
# - Set server-only vars in Vercel/production as "Secret"
# - Set public vars (NEXT_PUBLIC_*) in Vercel as regular env vars
# ─────────────────────────────────────────────────────────────

# ─── Public Variables (exposed to client) ───
# These are safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_PLACEHOLDER_anon_key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server-Only Variables (NEVER expose to client) ───
# These should be set in Vercel as "Secret" environment variables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_PLACEHOLDER_service_role_key
RESEND_API_KEY=re_PLACEHOLDER_resend_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
STRIPE_SECRET_KEY=sk_test_PLACEHOLDER
STRIPE_WEBHOOK_SECRET=whsec_PLACEHOLDER
PRICE_PLUS=price_plus_monthly_id
PRICE_PRO=price_pro_monthly_id
STRIPE_CUSTOMER_PORTAL_RETURN_URL=http://localhost:3000/account/billing
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/account/billing?checkout=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/account/billing?checkout=cancel

# ─── Redis (for worker queues) ───
REDIS_URL=redis://localhost:6379


# ─── Waitlist Mode (optional) ───
# Set to 'true' to enable waitlist-only mode (blocks all routes except /waitlist)
# NEXT_PUBLIC_WAITLIST_ONLY=false

# ─── Audiobook (queue + storage) ───
# Create Storage buckets in Supabase: `book_covers` can be public, `audiobooks` must be private
# AUDIOBOOK_ENABLED=true
# NEXT_PUBLIC_AUDIOBOOK_ENABLED=true
# AUDIOBOOK_STORAGE_BUCKET=audiobooks
# TTS_MAX_CHARS=1000
# TTS_TIMEOUT_MS=15000
# QWEN_TTS_BATCH_SIZE=1
# TTS_DTYPE=auto
# TTS_TORCH_COMPILE=0
# TTS_INT8=0
# TTS_CONCURRENCY=1
