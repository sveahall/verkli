# ─────────────────────────────────────────────────────────────
# Verkli Environment Variables
# ─────────────────────────────────────────────────────────────
# 
# This file contains all required environment variables for the Verkli app.
# Copy this to .env.local and fill in your actual values.
# 
# IMPORTANT: 
# - Never commit .env.local to git (it contains secrets)
# - Set server-only vars in Vercel/production as "Secret"
# - Set public vars (NEXT_PUBLIC_*) in Vercel as regular env vars
# ─────────────────────────────────────────────────────────────

# ─── Public Variables (exposed to client) ───
# These are safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://glfipbnsyxowqsmcuzcm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_cEGeutVe_1k5weWC_ESH6Q_GobDYiSX
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server-Only Variables (NEVER expose to client) ───
# These should be set in Vercel as "Secret" environment variables
SUPABASE_SERVICE_ROLE_KEY=sb_secret_IcT6OwpsefpPbZ9mLVlybA_m4Ee-WE5
RESEND_API_KEY=re_dKvRqLQ5dYC_48d5Wd7sC32d69c255d79f5
RESEND_FROM_EMAIL=hello@verkli.com

# ─── Redis (for worker queues) ───
REDIS_URL=redis://localhost:6379

# ─── RunwayML (for text-to-video AI) ───
RUNWAYML_API_SECRET=your-runway-api-secret-here

# ─── Waitlist Mode (optional) ───
# Set to 'true' to enable waitlist-only mode (blocks all routes except /waitlist)
# NEXT_PUBLIC_WAITLIST_ONLY=false

# ─── TTS (Text to Speech on Books page) ───
# Required for "Start TTS" on author book detail. Piper binary must be absolute path.
# Create Storage buckets in Supabase (public): book_covers, audiobooks, tts-outputs
# TTS_ENABLED=true
# TTS_BIN=/path/to/piper
# AUDIOBOOK_STORAGE_BUCKET=audiobooks
# TTS_STORAGE_BUCKET=tts-outputs
# TTS_MODEL_PATH=/path/to/vendor/tts/voices/sv_SE-nst-medium.onnx
# TTS_CONFIG_PATH=/path/to/vendor/tts/voices/sv_SE-nst-medium.onnx.json
# TTS_DATA_DIR=/path/to/vendor/tts/voices
# TTS_MAX_CHARS=1000
# TTS_TIMEOUT_MS=15000
