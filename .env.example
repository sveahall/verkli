# ─────────────────────────────────────────────────────────────
# Verkli Environment Variables
# ─────────────────────────────────────────────────────────────
# 
# This file contains all required environment variables for the Verkli app.
# Copy this to .env.local and fill in your actual values.
# 
# IMPORTANT: 
# - Never commit .env.local to git (it contains secrets)
# - Set server-only vars in Vercel/production as "Secret"
# - Set public vars (NEXT_PUBLIC_*) in Vercel as regular env vars
# ─────────────────────────────────────────────────────────────

# ─── Public Variables (exposed to client) ───
# These are safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Server-Only Variables (NEVER expose to client) ───
# These should be set in Vercel as "Secret" environment variables
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Database (for Prisma - optional, only if using Prisma directly) ───
# Note: Currently using Supabase client directly, so these are not required
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres

# ─── Redis (for worker queues - phase 2, not yet implemented) ───
REDIS_URL=redis://localhost:6379

# ─── RunwayML (for text-to-video AI) ───
RUNWAYML_API_SECRET=your-runway-api-secret-here

# ─── Waitlist Mode (optional) ───
# Set to 'true' to enable waitlist-only mode (blocks all routes except /waitlist)
# NEXT_PUBLIC_WAITLIST_ONLY=false
