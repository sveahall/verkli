# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database (Supabase Postgres connection string)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres"

# Redis (for worker queues - phase 2)
REDIS_URL="redis://localhost:6379"

# Storage (använd Supabase Storage istället)
# S3 behövs inte om du kör Supabase Storage

# RunwayML text→video
RUNWAYML_API_SECRET="your-runway-api-secret"
# CLI-only overrides (optional):
# RUNWAY_PROMPT_TEXT="A calm timelapse, clouds moving slowly."
# RUNWAY_DURATION=6
# RUNWAY_RATIO="1280:720"
# RUNWAY_AUDIO=0
